---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "¿Por qué elegirme? | Klgo. Jeremy Patricio Mancilla Maripan";
const description = "Conoce mi trayectoria, formación y compromiso con la salud de mis pacientes. Atención profesional personalizada en Santiago.";
---

<BaseLayout title={title} description={description}>
  <!-- Bio Section -->
  <section class="py-20 md:py-32 bg-background overflow-hidden reveal">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <div class="absolute -top-10 -left-10 w-40 h-40 bg-primary/5 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-10 -right-10 w-60 h-60 bg-accent/5 rounded-full blur-3xl"></div>
          
          <div class="relative rounded-[3rem] overflow-hidden shadow-2xl border-4 border-white transform hover:scale-[1.02] transition-transform duration-500 perspective-card">
            <img 
              src="/perfil.png" 
              alt="Klgo. Jeremy Patricio Mancilla Maripan" 
              class="w-full h-auto aspect-[4/5] object-cover"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute bottom-8 left-8 right-8 p-6 glass rounded-2xl">
              <p class="text-xl font-black text-foreground mb-1">Jeremy Patricio Mancilla</p>
              <p class="text-sm font-bold text-primary uppercase tracking-widest">Kinesiólogo Licenciado</p>
            </div>
          </div>
        </div>

        <div class="space-y-10 reveal stagger-1">
          <div class="space-y-4">
            <div class="inline-block px-4 py-1.5 bg-secondary/50 text-secondary-foreground rounded-full text-xs font-black uppercase tracking-widest">
                Trayectoria Profesional
            </div>
            <h1 class="text-5xl md:text-6xl font-black text-foreground tracking-tighter leading-tight">
              Vocación por el <span class="text-primary">Bienestar</span>
            </h1>
            <p class="text-xl text-muted-foreground leading-relaxed">
              Soy Kinesiólogo egresado de la Universidad Bernardo O'Higgins, comprometido con entregar una atención de salud de alta calidad, humana y técnica en el entorno más cómodo para el paciente: su propio hogar.
            </p>
          </div>

          <div class="grid gap-6">
            <div class="flex gap-6 p-6 bg-white rounded-3xl border border-primary/10 shadow-sm transition-all hover:shadow-md hover:border-primary/30 group">
                <div class="w-14 h-14 bg-primary/10 text-primary rounded-2xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                   <h3 class="text-xl font-bold text-foreground mb-1">Formación Continua</h3>
                   <p class="text-muted-foreground">Especialización en Kinesiología Neurológica, Respiratoria (Certificación IRA) y Musculoesquelética.</p>
                </div>
            </div>

            <div class="flex gap-6 p-6 bg-white rounded-3xl border border-primary/10 shadow-sm transition-all hover:shadow-md hover:border-primary/30 group">
                <div class="w-14 h-14 bg-secondary text-primary rounded-2xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div>
                   <h3 class="text-xl font-bold text-foreground mb-1">Humanismo Médico</h3>
                   <p class="text-muted-foreground">Atención empática para pacientes de todas las edades, desde pediatría hasta geriatría.</p>
                </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission/Vision Cards -->
  <section class="py-24 bg-secondary/20 reveal">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <div class="glass p-12 rounded-[3.5rem] space-y-6 animate-in fade-up">
            <div class="w-14 h-14 bg-primary text-white rounded-2xl flex items-center justify-center shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>
            </div>
            <h2 class="text-3xl font-black text-foreground">Misión</h2>
            <p class="text-lg text-muted-foreground leading-relaxed">
                Brindar servicios de kinesiología integral a domicilio, centrados en la recuperación funcional y el bienestar biopsicosocial de cada individuo, utilizando evidencia científica y tecnología portátil de primer nivel.
            </p>
        </div>

        <div class="glass p-12 rounded-[3.5rem] space-y-6 animate-in fade-up stagger-1">
            <div class="w-14 h-14 bg-accent text-white rounded-2xl flex items-center justify-center shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <h2 class="text-3xl font-black text-foreground">Visión</h2>
            <p class="text-lg text-muted-foreground leading-relaxed">
                Convertirme en el referente de kinesiología a domicilio en la Región Metropolitana, reconocido por la excelencia clínica, la calidez en el trato y la innovación constante en procesos de rehabilitación.
            </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-white text-center animate-in fade-up">
    <div class="container mx-auto px-4 space-y-10">
      <h2 class="text-4xl md:text-5xl font-black text-foreground tracking-tighter italic">"Tu recuperación comienza con una decisión"</h2>
      <div class="flex flex-wrap justify-center gap-6">
        <a href="https://wa.me/56936319077" class="btn-premium bg-primary text-white scale-110">Inicia tu Rehabilitación Ahora</a>
      </div>
    </div>
  </section>
</BaseLayout>
