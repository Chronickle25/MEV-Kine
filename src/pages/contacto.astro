---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Contacto | Agendamiento Directo de Kinesiología";
const description = "Ponte en contacto con KINE MEV para agendar tu evaluación. Resolvemos tus dudas por WhatsApp o Email en minutos.";
---

<BaseLayout title={title} description={description}>
  <section class="py-20 md:py-32 bg-background relative overflow-hidden reveal">
    <!-- Background Decor -->
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px] -z-10 animate-pulse"></div>

    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 md:gap-20 items-center">
          
          <div class="space-y-12 reveal stagger-1">
            <div class="space-y-6">
                <div class="inline-block px-4 py-1.5 bg-primary/10 text-primary rounded-full text-xs font-black uppercase tracking-widest">
                    Agendamiento Prioritario
                </div>
                <h1 class="text-4xl sm:text-6xl md:text-7xl font-black text-foreground tracking-tighter leading-[1.1]">
                    Hablemos de tu <span class="text-primary italic">Salud</span>
                </h1>
                <p class="text-lg md:text-xl text-muted-foreground leading-relaxed">
                    Resuelve tus dudas o coordina tu primera visita en menos de 5 minutos a través de nuestros canales directos.
                </p>
            </div>

            <div class="grid gap-6">
                <a href="https://wa.me/56936319077" class="group flex items-center p-6 md:p-8 bg-white rounded-[2rem] md:rounded-[2.5rem] shadow-sm border border-primary/10 hover:border-primary/40 hover:shadow-xl transition-all duration-300">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-[#25D366] text-white rounded-xl md:rounded-2xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform shadow-lg shadow-[#25D366]/20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="md:hidden"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden md:block"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    </div>
                    <div class="ml-4 md:ml-8 overflow-hidden">
                        <p class="text-[10px] md:text-xs font-black text-muted-foreground uppercase tracking-widest mb-1">WhatsApp Directo</p>
                        <p class="text-xl md:text-2xl font-black text-foreground truncate">+56 9 3631 9077</p>
                    </div>
                    <div class="ml-auto hidden sm:block opacity-0 group-hover:opacity-100 translate-x-4 group-hover:translate-x-0 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                </a>

                <div class="flex items-center p-6 md:p-8 bg-white rounded-[2rem] md:rounded-[2.5rem] shadow-sm border border-primary/10 transition-all">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-foreground text-white rounded-xl md:rounded-2xl flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="md:hidden"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden md:block"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    </div>
                    <div class="ml-4 md:ml-8 overflow-hidden">
                        <p class="text-[10px] md:text-xs font-black text-muted-foreground uppercase tracking-widest mb-1">Correo Electrónico</p>
                        <p class="text-sm md:text-xl font-bold text-foreground truncate">Klgo.jeremymancilla@gmail.com</p>
                    </div>
                </div>
            </div>
          </div>

          <div class="relative reveal stagger-2">
            <div class="absolute inset-0 bg-primary/10 rounded-[4rem] group-hover:rotate-6 transition-transform -z-10"></div>
            <div class="bg-white p-12 rounded-[3.5rem] shadow-2xl border border-primary/5 space-y-10 group perspective-card">
                <h3 class="text-2xl md:text-3xl font-black text-foreground flex items-center gap-4">
                    <span class="w-1.5 md:w-2 h-6 md:h-8 bg-accent rounded-full"></span>
                    Preguntas frecuentes
                </h3>
                
                <div class="space-y-8">
                    <div class="space-y-3">
                        <h4 class="text-lg font-bold text-primary italic">¿Qué necesito para la primera sesión?</h4>
                        <p class="text-muted-foreground leading-relaxed">Solo ropa cómoda y los exámenes o interconsultas médicas que tengas disponibles.</p>
                    </div>
                    <div class="space-y-3 pt-6 border-t border-primary/5">
                        <h4 class="text-lg font-bold text-primary italic">¿Atienden urgencias?</h4>
                        <p class="text-muted-foreground leading-relaxed">Tenemos disponibilidad prioritaria para patologías respiratorias infantiles y agudas.</p>
                    </div>
                </div>

                <div class="relative rounded-3xl overflow-hidden mt-8 shadow-xl">
                    <img 
                        src="/contacto.png" 
                        alt="Equipamiento Kinesiológico Premium" 
                        class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-1000"
                        loading="lazy"
                        decoding="async"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-foreground/50 to-transparent"></div>
                </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Decoration Map Area -->
  <section class="py-24 bg-white border-t border-secondary overflow-hidden reveal">
    <div class="container mx-auto px-4 text-center">
        <h2 class="text-xl font-black text-muted-foreground uppercase tracking-[0.3em] mb-16 opacity-40">Cobertura en toda la Región Metropolitana</h2>
        <div class="relative max-w-5xl mx-auto py-20">
            <!-- Simulated Map Visual -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full max-w-[800px] border-[16px] border-primary/5 rounded-full blur-2xl opacity-20"></div>
            <div class="relative flex flex-col items-center justify-center space-y-8">
                <div class="w-40 h-40 bg-primary/10 rounded-full flex items-center justify-center animate-pulse">
                    <div class="w-20 h-20 bg-primary/20 rounded-full flex items-center justify-center">
                        <div class="w-8 h-8 bg-primary rounded-full shadow-[0_0_40px_rgba(172,66,35,0.6)]"></div>
                    </div>
                </div>
                <div class="space-y-4">
                    <p class="text-3xl sm:text-5xl font-black text-foreground tracking-tighter leading-tight">Nos movemos por ti</p>
                    <p class="text-base md:text-lg text-muted-foreground font-medium">Llegamos a tu hogar sin importar la comuna.</p>
                </div>
                <div class="flex flex-wrap justify-center gap-3 pt-8 opacity-60">
                    {["Santiago Centro", "Las Condes", "Vitacura", "Ñuñoa", "El Bosque", "La Florida", "Puente Alto", "San Bernardo"].map((tag) => (
                        <span class="px-4 py-2 bg-secondary text-primary font-black rounded-xl text-xs uppercase tracking-widest">{tag}</span>
                    ))}
                    <span class="px-4 py-2 bg-primary/10 text-primary font-black rounded-xl text-xs uppercase tracking-widest">Y más...</span>
                </div>
            </div>
        </div>
    </div>
  </section>
</BaseLayout>
