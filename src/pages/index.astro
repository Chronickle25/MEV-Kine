  <script>
    async function initHeroAnimation() {
      const h1 = document.getElementById('hero-headline');
      if (!h1) return;

      const brandContainer = document.createElement('span');
      brandContainer.className = 'flex items-baseline transition-all duration-700';
      h1.appendChild(brandContainer);

      const phrase = "Movimiento Es Vida";
      const initialsIndices = [0, 11, 14]; 
      
      for (let i = 0; i < phrase.length; i++) {
        const span = document.createElement('span');
        span.textContent = phrase[i] === ' ' ? '\u0020' : phrase[i];
        span.className = 'letter';
        
        if (initialsIndices.includes(i)) {
          span.classList.add('initial');
          if (i === 11) span.id = 'initial-e';
        }
        
        brandContainer.appendChild(span);
        await new Promise(r => setTimeout(r, 70));
      }

      await new Promise(r => setTimeout(r, 1600));
      
      const allLetters = brandContainer.querySelectorAll('.letter');
      allLetters.forEach((letter, i) => {
        if (!initialsIndices.includes(i)) {
          letter.classList.add('collapsing');
        }
      });

      await new Promise(r => setTimeout(r, 700));
      brandContainer.id = 'brand-mev'; 
      brandContainer.classList.add('is-morphed');
      
      const eLetter = document.getElementById('initial-e');
      if (eLetter) eLetter.textContent = 'E';

      await new Promise(r => setTimeout(r, 600));
      
      const rest = " Kinesiología";
      const restContainer = document.createElement('span');
      restContainer.className = 'text-primary ml-[0.3em] inline-block'; 
      h1.appendChild(restContainer);

      for (let i = 0; i < rest.length; i++) {
        const charSpan = document.createElement('span');
        charSpan.textContent = rest[i] === ' ' ? '\u00A0' : rest[i];
        charSpan.className = 'animate-in fade-in slide-in-from-left-2 duration-700 blur-sm active:blur-0 inline-block';
        restContainer.appendChild(charSpan);
        setTimeout(() => charSpan.classList.remove('blur-sm'), 50);
        await new Promise(r => setTimeout(r, 600 / rest.length));
      }
    }

    setTimeout(initHeroAnimation, 800);

    // Stats Counter Animation
    const initCounters = () => {
      const stats = document.querySelectorAll('.stat-number');
      if (stats.length === 0) return;
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const target = entry.target as HTMLElement;
            const endValue = parseInt(target.getAttribute('data-target') || '0');
            animateCount(target, endValue);
            observer.unobserve(target);
          }
        });
      }, { threshold: 0.5 });

      stats.forEach(stat => observer.observe(stat));
    };

    const animateCount = (el: HTMLElement, end: number) => {
      let start = 0;
      const duration = 2000;
      const startTime = performance.now();

      const update = (now: number) => {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        
        // Easing function: easeOutExpo
        const easeProgress = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
        
        const current = Math.floor(easeProgress * end);
        el.textContent = current.toString();

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          el.textContent = end.toString();
        }
      };

      requestAnimationFrame(update);
    };

    initCounters();
  </script>
