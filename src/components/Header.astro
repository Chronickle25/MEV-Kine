---
const navItems = [
  { name: "Inicio", href: "/" },
  { name: "Servicios", href: "/servicios" },
  { name: "¿Por qué elegirme?", href: "/por-que-elegirme" },
  { name: "Precios", href: "/precios" },
  { name: "Contacto", href: "/contacto" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full transition-all duration-300 glass" id="main-header">
  <div class="container mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-lg p-1">
      <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white shadow-lg group-hover:scale-110 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      </div>
      <span class="text-xl font-extrabold tracking-tight text-foreground group-hover:text-primary transition-colors">KINE MEV</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class={`relative text-sm font-semibold transition-colors hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-md px-2 py-1 ${
            (currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))) 
            ? "text-primary" 
            : "text-muted-foreground"
          }`}
        >
          {item.name}
          {(currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))) && (
            <span class="absolute -bottom-1 left-0 w-full h-0.5 bg-primary rounded-full animate-in fade-in" />
          )}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a 
        href="https://wa.me/56936319077" 
        target="_blank" 
        class="hidden sm:inline-flex bg-[#25D366] text-white px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-[#128C7E] transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Agenda Ahora
      </a>

      <!-- Mobile Menu Toggle -->
      <button 
        id="mobile-menu-toggle" 
        class="md:hidden p-2 text-foreground hover:bg-black/5 rounded-xl transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
        aria-label="Menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Content -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-16 left-0 w-full bg-white/95 backdrop-blur-xl border-b shadow-xl animate-in slide-in-from-top duration-300">
    <nav class="flex flex-col p-6 gap-4">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class={`text-lg font-bold p-2 rounded-xl transition-colors ${
            currentPath === item.href ? "bg-primary/10 text-primary" : "text-muted-foreground hover:bg-black/5"
          }`}
        >
          {item.name}
        </a>
      ))}
      <a 
        href="https://wa.me/56936319077" 
        class="mt-4 bg-[#25D366] text-white p-4 rounded-2xl font-bold text-center flex items-center justify-center gap-3 shadow-lg"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        WhatsApp Directo
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Header scroll effect
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-lg');
    } else {
      header?.classList.remove('shadow-lg');
    }
  });
</script>
