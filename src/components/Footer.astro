---
const currentYear = new Date().getFullYear();
const whatsappUrl = "https://wa.me/56936319077?text=Hola,%20me%20gustaría%20agendar%20una%20consulta%20de%20kinesiología";
---

<footer class="w-full bg-foreground text-background py-16 mt-auto rounded-t-[2.5rem] relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-primary/10 to-transparent opacity-30 pointer-events-none"></div>
  <div class="container px-4 md:px-6 mx-auto relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 items-start justify-items-center md:justify-items-start text-center md:text-left">
      
      <!-- Brand & Description -->
      <div class="space-y-4 max-w-xs flex flex-col items-center md:items-start">
        <a href="/" class="flex flex-col items-center md:items-start gap-4 group focus-visible:outline-none">
          <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center text-white shadow-xl shadow-primary/20 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </div>
          <span class="text-3xl font-black tracking-tighter text-white">KINE MEV</span>
        </a>
        <p class="text-muted-foreground/80 text-sm leading-relaxed mt-2">
          Atención profesional personalizada en la comodidad de tu hogar. Rehabilitación enfocada en tus objetivos.
        </p>
      </div>
      
      <!-- Quick Links -->
      <div class="space-y-6 flex flex-col items-center md:items-start">
        <h3 class="font-bold text-white tracking-widest uppercase text-xs opacity-80">Menú Rápido</h3>
        <nav class="flex flex-col gap-3">
          <a href="/" class="text-muted-foreground/80 hover:text-white transition-colors text-sm flex items-center gap-2 group w-fit">
            <span class="w-1 h-1 rounded-full bg-primary opacity-0 group-hover:opacity-100 transition-opacity"></span>
            Inicio
          </a>
          <a href="/servicios" class="text-muted-foreground/80 hover:text-white transition-colors text-sm flex items-center gap-2 group w-fit">
            <span class="w-1 h-1 rounded-full bg-primary opacity-0 group-hover:opacity-100 transition-opacity"></span>
            Servicios
          </a>
          <a href="/por-que-elegirme" class="text-muted-foreground/80 hover:text-white transition-colors text-sm flex items-center gap-2 group w-fit">
            <span class="w-1 h-1 rounded-full bg-primary opacity-0 group-hover:opacity-100 transition-opacity"></span>
            ¿Por qué elegirme?
          </a>
          <a href="/precios" class="text-muted-foreground/80 hover:text-white transition-colors text-sm flex items-center gap-2 group w-fit">
            <span class="w-1 h-1 rounded-full bg-primary opacity-0 group-hover:opacity-100 transition-opacity"></span>
            Precios
          </a>
        </nav>
      </div>

      <!-- Contact -->
      <div class="space-y-6 flex flex-col items-center md:items-start">
        <h3 class="font-bold text-white tracking-widest uppercase text-xs opacity-80">Contacto</h3>
        <div class="flex flex-col gap-4 text-sm text-muted-foreground/80">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center hover:text-white transition-colors group justify-center md:justify-start"
          >
            <div class="w-8 h-8 rounded-full bg-[#25D366]/20 text-[#25D366] flex items-center justify-center mr-3 group-hover:bg-[#25D366] group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 2.81 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
            </div>
            +56 9 3631 9077
          </a>
          <div class="flex items-start text-center md:text-left">
            <div class="w-8 h-8 rounded-full bg-primary/20 text-primary flex items-center justify-center mr-3 shrink-0 hidden md:flex">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <span class="mt-1 leading-snug">Psj. San Alejandro I 1877,<br/>El Bosque, Región Metropolitana</span>
          </div>
        </div>
        
        <a href="/contacto" class="mt-4 px-6 py-2.5 rounded-full bg-white/5 text-white border border-white/10 hover:bg-white hover:text-black transition-colors text-sm font-semibold">
          Escríbeme
        </a>
      </div>
      
    </div>

    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col items-center justify-between text-xs text-muted-foreground/50 gap-4 md:flex-row">
      <p>© {currentYear} KINE MEV. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
