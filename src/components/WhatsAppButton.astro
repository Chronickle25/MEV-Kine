---
---
<a 
  href="https://wa.me/56936319077?text=Hola,%20quiero%20agendar%20una%20evaluación%20kinesiológica" 
  target="_blank" 
  id="whatsapp-magnetic"
  class="fixed bottom-8 right-8 z-[100] group flex items-center justify-center pointer-events-auto reveal"
  aria-label="Contactar por WhatsApp"
>
  <!-- Main Button -->
  <div class="magnetic-inner relative flex items-center justify-center w-16 h-16 bg-[#25D366] text-white rounded-2xl shadow-[0_10px_40px_-10px_rgba(37,211,102,0.5)] transition-all duration-300 group-hover:scale-110 group-active:scale-95">
    
    <!-- Outer Pulse Animation -->
    <span class="absolute inset-0 rounded-2xl bg-[#25D366] animate-ping opacity-25 group-hover:hidden"></span>
    
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 transition-transform duration-500 group-hover:rotate-12"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
  </div>

  <!-- Label Tip -->
  <span class="absolute right-24 bg-white text-slate-800 px-4 py-2 rounded-xl text-sm font-bold shadow-xl opacity-0 translate-x-4 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0 whitespace-nowrap border">
    ¿Tienes dudas? ¡Escríbeme!
    <span class="absolute -right-2 top-1/2 -translate-y-1/2 w-4 h-4 bg-white rotate-45 border-r border-t border-transparent"></span>
  </span>
</a>

<script>
  // Magnetic Effect for WhatsApp Button
  const button = document.getElementById('whatsapp-magnetic');
  const inner = button?.querySelector('.magnetic-inner') as HTMLElement;

  if (button && inner) {
    button.addEventListener('mousemove', (e) => {
      const rect = button.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      
      inner.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px) scale(1.1)`;
    });

    button.addEventListener('mouseleave', () => {
      inner.style.transform = `translate(0px, 0px) scale(1)`;
    });
  }
</script>

<style>
  /* Entrance delay specific to layout reveal logic if needed */
  .reveal {
    transition-delay: 1.5s;
  }
</style>
